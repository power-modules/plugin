{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "power-modules/plugin",
    "description": "A modular plugin component for the Power Modules framework, enabling seamless integration and extension of functionalities.",
    "type": "library",
    "keywords": [
        "modular",
        "framework",
        "power-modules",
        "dependency-injection",
        "encapsulation",
        "microservices",
        "modular-architecture",
        "di-container",
        "component-based",
        "plugin-system",
        "ecosystem",
        "powermodulesetup"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Evgenii Teterin",
            "email": "roundcubez@gmail.com",
            "role": "Owner"
        }
    ],
    "autoload": {
        "psr-4": {
            "Modular\\Plugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Modular\\Plugin\\Test\\": "test/"
        }
    },
    "require": {
        "php": "^8.4",
        "power-modules/framework": "^2.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.3",
        "friendsofphp/php-cs-fixer": "^3.88",
        "phpstan/phpstan": "^2.1"
    }
}
